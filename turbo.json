{
  "$schema": "https://v2-9-6.turborepo.dev/schema.json",
  "globalEnv": ["NODE_ENV", "NEXT_PUBLIC_GITHUB_STARS_ENABLED"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", ".vinxi/**", ".output/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types", "^build"]
    },
    "test": {
      "inputs": ["$TURBO_DEFAULT$", "src/**", "vitest.config.ts"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    }
  }
}
